---
import BaseLayout from '../layouts/BaseLayout.astro';

const highlights = [
  {
    title: 'Chemical Process Design',
    body: 'Process piping design (ASME B31.3), instrument selection, and pump optimization for chemical plant service. Have a look at <a href="https://www.totalaspectdesign.com/">TAD</a> for more information.',
  },
  {
    title: 'Apps, Software & Websites',
    body: 'Built with React Native, Expo, and Supabase. Published on App Store, personal and commercial use. Check out some <a href="/projects/">examples</a>. Fast static websites built with Astro.',
  },
  {
    title: 'Personal Projects',
    body: 'Woodworking, home electronics, <a href="/blog/">writing</a> about things I do a deep dive on so I have somewhere to publish them. Maybe some shower thoughts.. whatever comes to mind.',
  },
];
---

<BaseLayout title="Home">
  <div class="hero">
    <div>
      <p class="eyebrow">Engineer &middot; Licensed PE (South Carolina)</p>
      <h1>Engineering at the Intersection of Disciplines.</h1>
      <p class="lede">
        Hey There! I'm Andrew, an engineer living in Upstate South Carolina. Welcome to my site.
        I practice process design at <a href="https://www.totalaspectdesign.com">Total Aspect Design</a>, this site is
        my home base for everything else I <a href="/projects/">make</a>, or feel like <a href="/blog/">writing</a> about.
      </p>
      <p>
        <a class="button" href="/projects/">See what I've built</a>
      </p>
    </div>
    <img class="headshot" src="/images/Me.jpg" alt="Andrew Bieber" />
  </div>

  <div class="grid cols-3" style="margin-top: 3rem;">
    {highlights.map((item) => (
      <div class="card">
        <h3 style="margin-top: 0;">{item.title}</h3>
        <p style="color: var(--color-text-muted); margin-bottom: 0;" set:html={item.body} />
      </div>
    ))}
  </div>
</BaseLayout>
