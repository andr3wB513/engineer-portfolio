---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const studies = (await getCollection('caseStudies')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Portfolio">
  <p class="eyebrow">Portfolio</p>
  <h1>Examples of work</h1>
  <p class="lede">
    Representative examples of process design work. Project-specific details are
    generalized or redacted; the engineering approach is real.
  </p>

  {studies.map((study) => (
    <div class="card">
      <p class="eyebrow" style="margin-top: 0;">{study.data.category}</p>
      <h2 style="margin-top: 0;">
        <a href={`/portfolio/${study.id}/`}>{study.data.title}</a>
      </h2>
      <p style="color: var(--color-text-muted);">{study.data.summary}</p>
      <div>
        {study.data.tools.map((tool) => <span class="tag">{tool}</span>)}
      </div>
    </div>
  ))}
</BaseLayout>
