---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  {
    title: 'Piping System Design (ASME B31.3)',
    description:
      "Process piping design in accordance with ASME B31.3, including line sizing, material selection, and code compliance for chemical plant service.",
    details: [
      'Thermal expansion & flexibility analysis (pipe stress screening and detailed CAESAR II modeling)',
      'Pressure relief system design: relief scenario identification, device sizing, and relief header/flare tie-in design',
      'Line list and specification development',
    ],
  },
  {
    title: 'Instrument Specification Packages',
    description:
      'Preparing complete instrument specification packages suitable for competitive vendor quoting.',
    details: [
      'Instrument datasheets (flow, level, pressure, temperature, control valves, relief devices)',
      'Bid package support and technical bid evaluation',
      'Coordination with construction crew and vendors through procurement',
    ],
  },
  {
    title: 'PFD & P&ID Development',
    description:
      'Process flow diagrams and piping & instrumentation diagrams that document design intent for engineering, construction, and operations.',
    details: [
      'Mass and energy balance-driven PFDs',
      'P&ID development and markup through HAZOP and design review cycles',
      'Redline management and as-built documentation',
    ],
  },
];
---

<BaseLayout title="Skills">
  <p class="eyebrow">Skills</p>
  <h1>What I do</h1>
  <p class="lede">Core areas of process design practice, with the specific engineering work behind each.</p>

  {skills.map((skill) => (
    <div class="card">
      <h2 style="margin-top: 0;">{skill.title}</h2>
      <p style="color: var(--color-text-muted);">{skill.description}</p>
      <ul>
        {skill.details.map((d) => <li>{d}</li>)}
      </ul>
    </div>
  ))}
</BaseLayout>
